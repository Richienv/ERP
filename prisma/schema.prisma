// ================================
// Discount Scheme (CSA-013)
// ================================

enum DiscountType {
  PERCENTAGE // Persentase potongan (5%, 10%)
  FIXED      // Potongan tetap (Rp 5.000/unit)
  TIERED     // Bertingkat berdasarkan kuantitas
}

enum DiscountScope {
  GLOBAL      // Berlaku untuk semua produk
  PRICELIST   // Berlaku pada daftar harga tertentu
  CUSTOMER    // Berlaku untuk pelanggan tertentu
  PRODUCT     // Berlaku untuk produk tertentu
  CATEGORY    // Berlaku untuk kategori tertentu
}

model DiscountScheme {
  id          String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code        String        @unique
  name        String
  description String?
  type        DiscountType
  scope       DiscountScope @default(GLOBAL)
  isActive    Boolean       @default(true)

  // Flat discount fields (PERCENTAGE / FIXED)
  value Decimal? @db.Decimal(20, 2) // percentage value or fixed amount

  // Tiered rules (TIERED type) — JSON array: [{minQty, maxQty, discount}]
  tieredRules Json?

  // Scope relations (nullable — set based on scope)
  priceListId String?   @db.Uuid
  customerId  String?   @db.Uuid
  productId   String?   @db.Uuid
  categoryId  String?   @db.Uuid

  priceList PriceList? @relation(fields: [priceListId], references: [id])
  customer  Customer?  @relation(fields: [customerId], references: [id])
  product   Product?   @relation(fields: [productId], references: [id])
  category  Category?  @relation(fields: [categoryId], references: [id])

  // Validity period
  validFrom DateTime?
  validTo   DateTime?

  // Minimum order value (optional)
  minOrderValue Decimal? @db.Decimal(20, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, isActive])
  @@index([scope])
  @@index([priceListId])
  @@index([customerId])
  @@index([productId])
  @@index([categoryId])
  @@map("discount_schemes")
}

// ================================
// Costing
