// ================================
// General Ledger (Accounting)
// ================================

model GLAccount {
  id       String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code     String      @unique // e.g. "1010"
  name     String // e.g. "Bank BCA"
  type     AccountType    // ASSET, LIABILITY, etc.
  subType  AccountSubType @default(GENERAL)
  balance  Decimal        @default(0) @db.Decimal(20, 2)
  isSystem Boolean     @default(false) // If true, cannot be deleted (e.g. Retained Earnings)
  isControlAccount  Boolean @default(false) // AR, AP, Inventory — sub-ledger controlled
  allowDirectPosting Boolean @default(true) // false = block manual journal entries

  // Hierarchy
  parentId  String?     @db.Uuid
  parent    GLAccount?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children  GLAccount[] @relation("AccountHierarchy")

  lines               JournalLine[]
  bankReconciliations BankReconciliation[]
  bankAccounts        BankAccount[]
  pettyCashBankTxns     PettyCashTransaction[] @relation("PettyCashBank")
  pettyCashExpenseTxns  PettyCashTransaction[] @relation("PettyCashExpense")
  budgetLines           BudgetLine[]
  cashflowPlanItems     CashflowPlanItem[]

  // Customer AR/AP overrides
  arCustomers Customer[] @relation("CustomerAR")
  apCustomers Customer[] @relation("CustomerAP")

  // Product accounting relations
  productsAsCogs      Product[] @relation("ProductCogs")
  productsAsInventory Product[] @relation("ProductInventory")
  productsAsIncome    Product[] @relation("ProductIncome")
  productsAsPurchase  Product[] @relation("ProductPurchase")

  // Fixed Asset relations
  fixedAssetCategoriesAsset   FixedAssetCategory[] @relation("CategoryAssetAccount")
  fixedAssetCategoriesAccDep  FixedAssetCategory[] @relation("CategoryAccDepAccount")
  fixedAssetCategoriesDepExp  FixedAssetCategory[] @relation("CategoryDepExpAccount")
  fixedAssetCategoriesGainLoss FixedAssetCategory[] @relation("CategoryGainLossAccount")

  // Cash Flow Statement (CFS) classification
  // OPERATING | INVESTING | FINANCING | NON_CASH | EXCLUDED
  cfsActivity          String?
  // Named line on the CFS statement (e.g. "Change in AR", "Purchase of Fixed Assets")
  cfsLineItem          String?
  // INFLOW | OUTFLOW | ADJUSTMENT | NOT_APPLICABLE
  cfsDirection         String?
  // true = accountant must manually tag each journal line for this account
  cfsRequiresOverride  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([code])
  @@index([cfsActivity])
  @@map("gl_accounts")
}

// Journal Entry
model JournalEntry {
  id          String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  date        DateTime    @default(now())
  description String
  reference   String? // e.g. "INV-001"
  status      EntryStatus @default(POSTED)

  // Recurring journal entries (Textile upgrade)
  isRecurring       Boolean   @default(false)
  recurringPattern  String? // e.g. "MONTHLY", "WEEKLY"
  nextRecurringDate DateTime?

  // Reversal tracking
  isReversed   Boolean  @default(false) @map("is_reversed")
  reversedById String?  @unique @db.Uuid @map("reversed_by_id")
  reversedBy   JournalEntry? @relation("JournalReversal", fields: [reversedById], references: [id])
  reversalOf   JournalEntry? @relation("JournalReversal")

  invoiceId              String? @db.Uuid
  paymentId              String? @db.Uuid
  salesOrderId           String? @db.Uuid
  purchaseOrderId        String? @db.Uuid
  inventoryTransactionId String? @db.Uuid

  lines                JournalLine[]
  invoice              Invoice?              @relation(fields: [invoiceId], references: [id])
  payment              Payment?              @relation(fields: [paymentId], references: [id])
  salesOrder           SalesOrder?           @relation(fields: [salesOrderId], references: [id])
  purchaseOrder        PurchaseOrder?        @relation(fields: [purchaseOrderId], references: [id])
  inventoryTransaction InventoryTransaction? @relation(fields: [inventoryTransactionId], references: [id])
  pettyCashTransaction  PettyCashTransaction?
  debitCreditNote      DebitCreditNote?
  fixedAssetDeprecEntries FixedAssetDeprecEntry[]
  fixedAssetMovements     FixedAssetMovement[]

  // Reconciliation stamp — written when bank recon item is CONFIRMED
  isReconciled        Boolean   @default(false)
  reconciledAt        DateTime?
  reconciledBy        String?   @db.Uuid
  reconciliationId    String?   @db.Uuid
  bankItemRef         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([isReconciled])
  @@map("journal_entries")
}

model JournalLine {
  id        String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  entryId   String @db.Uuid
  accountId String @db.Uuid

  description String?
  debit       Decimal @default(0) @db.Decimal(20, 2)
  credit      Decimal @default(0) @db.Decimal(20, 2)

  // CFS override: accountant can manually tag a single line when account-level tag is ambiguous
  cfsActivityOverride  String?  // overrides account.cfsActivity for this line
  cfsLineItemOverride  String?  // overrides account.cfsLineItem for this line
  cfsRequiresOverride  Boolean  @default(false) // true = unresolved, blocks CFS generation

  entry   JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account GLAccount    @relation(fields: [accountId], references: [id])

  @@index([entryId])
  @@index([accountId])
  @@index([cfsRequiresOverride])
  @@map("journal_lines")
}

