model Invoice {
  id              String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  number          String  @unique
  quoteId         String? @db.Uuid // Optional link to quote
  orderId         String? @db.Uuid // Legacy polymorphic reference (prefer explicit relations below)
  salesOrderId       String? @db.Uuid
  purchaseOrderId    String? @db.Uuid
  purchaseRequestId  String? @db.Uuid

  // Polymorphic-ish Relation
  customerId String? @db.Uuid // For AR (Sales)
  supplierId String? @db.Uuid // For AP (Purchasing)

  type InvoiceType // INV_OUT (Customer), INV_IN (Supplier)

  // Dates
  issueDate DateTime @default(now())
  dueDate   DateTime

  // Amounts — Decimal(20,2) supports up to 999,999,999,999,999,999.99
  subtotal       Decimal @db.Decimal(20, 2)
  taxAmount      Decimal @db.Decimal(20, 2)
  discountAmount Decimal @default(0) @db.Decimal(20, 2)
  totalAmount    Decimal @db.Decimal(20, 2)
  balanceDue     Decimal @db.Decimal(20, 2) // Sisa tagihan

  // Multi-currency
  currencyCode  String   @default("IDR")
  exchangeRate  Decimal  @default(1) @db.Decimal(15, 4)
  amountInIDR   Decimal  @default(0) @db.Decimal(20, 2)

  status InvoiceStatus @default(DRAFT)

  // User-selected GL account code for revenue (INV_OUT) or expense (INV_IN) posting
  // When set, moveInvoiceToSent() uses this instead of hardcoded SYS_ACCOUNTS.REVENUE / EXPENSE_DEFAULT
  glAccountCode String?

  // Relations
  customer       Customer?      @relation(fields: [customerId], references: [id])
  supplier       Supplier?      @relation(fields: [supplierId], references: [id])
  salesOrder     SalesOrder?    @relation(fields: [salesOrderId], references: [id])
  purchaseOrder   PurchaseOrder?  @relation(fields: [purchaseOrderId], references: [id])
  purchaseRequest PurchaseRequest? @relation(fields: [purchaseRequestId], references: [id])
  items              InvoiceItem[]
  payments           Payment[]
  journalEntries     JournalEntry[]
  dcNoteOrigins      DebitCreditNote[]           @relation("DCNoteOriginalInvoice")
  dcNoteSettlements  DebitCreditNoteSettlement[]  @relation("DCNoteSettlements")
  attachments        InvoiceAttachment[]
  withholdingTaxes   WithholdingTax[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, status])
  @@index([issueDate])
  @@index([dueDate])
  @@index([customerId])
  @@index([supplierId])
  @@map("invoices")
}

model InvoiceItem {
  id        String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  invoiceId String  @db.Uuid
  productId String? @db.Uuid // Optional (could be service/text)

  description String
  quantity    Decimal @db.Decimal(10, 3)
  unitPrice   Decimal @db.Decimal(20, 2)
  amount      Decimal @db.Decimal(20, 2)

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([invoiceId])
  @@index([productId])
  @@map("invoice_items")
}

model InvoiceAttachment {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  invoiceId  String   @db.Uuid
  invoice    Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  fileName   String
  fileUrl    String
  fileType   String
  fileSize   Int
  uploadedAt DateTime @default(now())

  @@index([invoiceId])
}

model Payment {
  id         String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  number     String  @unique
  invoiceId  String? @db.Uuid // Optional (could be advance payment/deposit)
  customerId String? @db.Uuid // Payer
  supplierId String? @db.Uuid // Payee

  date      DateTime      @default(now())
  amount    Decimal       @db.Decimal(20, 2)
  method    PaymentMethod @default(TRANSFER)
  reference String? // Cheque Num, Transfer Ref

  whtAmount Decimal?      @db.Decimal(20, 2) // Withholding tax amount (PPh 23/PPh 21)
  whtRate   Decimal?      @db.Decimal(5, 4)  // WHT rate (e.g. 0.0200 = 2%)

  notes String?

  glPostingStatus String @default("POSTED") // PENDING | POSTED | FAILED

  invoice          Invoice?       @relation(fields: [invoiceId], references: [id])
  customer         Customer?      @relation(fields: [customerId], references: [id])
  supplier         Supplier?      @relation(fields: [supplierId], references: [id])
  journalEntries   JournalEntry[]
  withholdingTaxes WithholdingTax[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invoiceId])
  @@map("payments")
}

enum InvoiceType {
  INV_OUT // Piutang/Tagihan ke Customer
  INV_IN // Hutang/Tagihan dari Supplier
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
  VOID
  DISPUTED
}

enum PaymentMethod {
  CASH
  TRANSFER
  CHECK
  GIRO
  CREDIT_CARD
  OTHER
}

enum PPhType {
