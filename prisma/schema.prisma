// ================================
// Fixed Asset Register (Aset Tetap)
// ================================

enum DepreciationMethod {
  STRAIGHT_LINE      // Garis Lurus
  DECLINING_BALANCE  // Saldo Menurun
  UNITS_OF_PRODUCTION // Unit Produksi
}

enum DepreciationFrequency {
  MONTHLY // Bulanan
  YEARLY  // Tahunan
}

enum AssetStatus {
  DRAFT              // Draf
  ACTIVE             // Aktif
  FULLY_DEPRECIATED  // Disusutkan Penuh
  DISPOSED           // Dihapus
  SOLD               // Dijual
  WRITTEN_OFF        // Dihapusbukukan
}

enum AssetMovementType {
  DISPOSAL   // Penghapusan
  SALE       // Penjualan
  WRITE_OFF  // Hapus Buku
  TRANSFER   // Transfer
}

enum DepreciationRunStatus {
  PREVIEW  // Pratinjau
  POSTED   // Diposting
  REVERSED // Dibatalkan
}

model FixedAssetCategory {
  id          String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code        String  @unique
  name        String // e.g. "Mesin", "Kendaraan", "Komputer", "Furnitur", "Bangunan"
  description String?

  defaultMethod       DepreciationMethod    @default(STRAIGHT_LINE)
  defaultUsefulLife    Int                   @default(60) // bulan
  defaultResidualPct  Decimal               @default(0) @db.Decimal(5, 2) // % dari harga beli

  // Akun GL default untuk kategori ini
  assetAccountId      String?  @db.Uuid
  accDepAccountId     String?  @db.Uuid
  depExpAccountId     String?  @db.Uuid
  gainLossAccountId   String?  @db.Uuid

  assetAccount    GLAccount? @relation("CategoryAssetAccount", fields: [assetAccountId], references: [id])
  accDepAccount   GLAccount? @relation("CategoryAccDepAccount", fields: [accDepAccountId], references: [id])
  depExpAccount   GLAccount? @relation("CategoryDepExpAccount", fields: [depExpAccountId], references: [id])
  gainLossAccount GLAccount? @relation("CategoryGainLossAccount", fields: [gainLossAccountId], references: [id])

  isActive Boolean @default(true)
  assets   FixedAsset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("fixed_asset_categories")
}

model FixedAsset {
  id         String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  assetCode  String @unique // Auto-generated: FA-XXXX
  name       String
  categoryId String @db.Uuid

  // Informasi pembelian
  purchaseDate      DateTime  @db.Date
  capitalizationDate DateTime @db.Date
  supplierId        String?   @db.Uuid
  purchaseCost      Decimal   @db.Decimal(20, 2)
  residualValue     Decimal   @default(0) @db.Decimal(20, 2)

  // Penyusutan
  usefulLifeMonths     Int
  depreciationMethod   DepreciationMethod @default(STRAIGHT_LINE)
  depreciationFrequency DepreciationFrequency @default(MONTHLY)
  depreciationStartDate DateTime @db.Date

  // Akumulasi (denormalized for performance)
  accumulatedDepreciation Decimal @default(0) @db.Decimal(20, 2)
  netBookValue            Decimal @default(0) @db.Decimal(20, 2) // purchaseCost - accumulatedDepreciation

  // Lokasi & identifikasi
  location     String?
  department   String?
  serialNumber String?
  notes        String?

  status AssetStatus @default(DRAFT)

  // Relasi
  category  FixedAssetCategory @relation(fields: [categoryId], references: [id])
  supplier  Supplier?          @relation(fields: [supplierId], references: [id])

  depreciationSchedules FixedAssetDeprecSchedule[]
  depreciationEntries   FixedAssetDeprecEntry[]
  movements             FixedAssetMovement[]
  vehicle               Vehicle? // mining edition: 1:1 link if asset is a vehicle

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([status])
  @@index([supplierId])
  @@map("fixed_assets")
}

model FixedAssetDeprecSchedule {
  id       String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  assetId  String @db.Uuid
  periodNo Int // 1, 2, 3, ... (nomor periode penyusutan)

  scheduledDate      DateTime @db.Date
  depreciationAmount Decimal  @db.Decimal(20, 2)
  accumulatedAmount  Decimal  @db.Decimal(20, 2)
  bookValueAfter     Decimal  @db.Decimal(20, 2)
  isPosted           Boolean  @default(false) // Sudah di-posting via depreciation run?

  asset FixedAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, periodNo])
  @@index([assetId])
  @@index([scheduledDate])
  @@map("fixed_asset_deprec_schedules")
}

model FixedAssetDeprecRun {
  id          String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  runDate     DateTime             @default(now())
  periodStart DateTime             @db.Date
  periodEnd   DateTime             @db.Date
  status      DepreciationRunStatus @default(PREVIEW)

  totalAssets       Int
  totalDepreciation Decimal @db.Decimal(20, 2)

  postedBy   String?   @db.Uuid
  postedAt   DateTime?
  reversedBy String?   @db.Uuid
  reversedAt DateTime?
  notes      String?

  entries FixedAssetDeprecEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([periodStart, periodEnd])
  @@map("fixed_asset_deprec_runs")
}

model FixedAssetDeprecEntry {
  id    String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  runId String @db.Uuid
  assetId String @db.Uuid

  depreciationAmount    Decimal @db.Decimal(20, 2)
  accumulatedAfter      Decimal @db.Decimal(20, 2)
  bookValueAfter        Decimal @db.Decimal(20, 2)

  journalEntryId String? @db.Uuid

  run          FixedAssetDeprecRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  asset        FixedAsset          @relation(fields: [assetId], references: [id])
  journalEntry JournalEntry?       @relation(fields: [journalEntryId], references: [id])

  @@unique([runId, assetId])
  @@index([runId])
  @@index([assetId])
  @@map("fixed_asset_deprec_entries")
}

model FixedAssetMovement {
  id      String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  assetId String            @db.Uuid
  type    AssetMovementType
  date    DateTime          @db.Date

  // Disposal / Sale fields
  proceeds     Decimal? @db.Decimal(20, 2) // Hasil penjualan
  gainLoss     Decimal? @db.Decimal(20, 2) // Laba/Rugi disposal

  // Transfer fields
  fromLocation   String?
  fromDepartment String?
  toLocation     String?
  toDepartment   String?

  notes          String?
  journalEntryId String? @db.Uuid

  executedBy String? @db.Uuid

  asset        FixedAsset    @relation(fields: [assetId], references: [id])
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id])

  createdAt DateTime @default(now())

  @@index([assetId])
  @@index([type])
  @@map("fixed_asset_movements")
}

// ============================================================================
// Document Numbering
// ============================================================================

/// Atomic per-prefix counter for generating sequential document numbers
/// (GRN, Stock Transfer, Invoice, etc.) without count()+1 race conditions.
/// Use via lib/document-numbering.ts → getNextDocNumber(tx, prefix).
model DocumentCounter {
  id     String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  prefix String
  value  Int    @default(0)

  updatedAt DateTime @updatedAt

  @@unique([prefix])
  @@map("document_counters")
}

// ============================================================================
// Vehicle / Armada (Mining Edition)
// ============================================================================
//
// Master data untuk armada: rental fleet, alat berat, kendaraan customer
// (untuk service order). Optional 1:1 ke FixedAsset (untuk depresiasi
// kendaraan owned). Optional ke Customer (untuk vehicle yang dimiliki
// customer eksternal — service order saja).

model Vehicle {
  id           String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid

  // Identification
  plateNumber  String  @unique // e.g. "BD 1234 ABC"
  vin          String?         // Vehicle Identification Number / chassis
  engineNumber String?

  // Make / model
  brand   String  // Toyota, Mitsubishi, Komatsu
  model   String  // Hilux Double Cabin 4x4, PC200-8
  variant String? // 2.4L V Diesel, etc
  year    Int
  color   String?

  // Documents (penting untuk compliance tambang)
  bpkbNumber             String?
  stnkNumber             String?
  stnkExpiry             DateTime? @db.Date
  kirNumber              String?   // Uji KIR (kendaraan niaga / tambang)
  kirExpiry              DateTime? @db.Date
  insurancePolicyNumber  String?
  insuranceExpiry        DateTime? @db.Date
  insurer                String?

  // Operational
  vehicleType     VehicleType   @default(LIGHT_VEHICLE)
  status          VehicleStatus @default(AVAILABLE)
  warehouseId     String?       @db.Uuid // Lokasi current
  warehouse       Warehouse?    @relation(fields: [warehouseId], references: [id])
  currentLocation String?       // Free-text override (e.g. "Site Tabang")

  // Operational metrics (untuk maintenance scheduling)
  odometer    Int?     // km — light vehicle
  engineHours Decimal? @db.Decimal(10, 1) // jam kerja — heavy equipment

  // Rental rates (kalau tersedia untuk disewakan)
  dailyRate   Decimal? @db.Decimal(20, 2)
  monthlyRate Decimal? @db.Decimal(20, 2)

  // Linked records
  /// FixedAsset link — kalau vehicle terdaftar sebagai aset perusahaan
  /// (untuk depresiasi via FixedAsset module).
  fixedAssetId String?     @unique @db.Uuid
  fixedAsset   FixedAsset? @relation(fields: [fixedAssetId], references: [id])

  /// Customer ownership — set kalau vehicle MILIK CUSTOMER (service order
  /// untuk customer eksternal). NULL = milik perusahaan (rental fleet).
  ownerCustomerId String?   @db.Uuid
  ownerCustomer   Customer? @relation("CustomerVehicles", fields: [ownerCustomerId], references: [id])

  // Notes
  notes    String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([vehicleType])
  @@index([ownerCustomerId])
  @@index([warehouseId])
  @@map("vehicles")
}

enum VehicleType {
  LIGHT_VEHICLE   // Hilux DC, Triton, Pickup
  HEAVY_EQUIPMENT // PC200, Bulldozer, Wheel Loader
  TRUCK           // Dump truck, hauling truck
  TRAILER         // Trailer, lowbed
  MOTORCYCLE      // ATV / motor
  OTHER
}

enum VehicleStatus {
  AVAILABLE   // Siap untuk disewakan / digunakan
  RENTED      // Sedang disewa customer
  IN_SERVICE  // Sedang di workshop
  RESERVED    // Booked tapi belum aktif
  SOLD        // Sudah dijual
  WRITTEN_OFF // Disposed / scrapped
  INACTIVE    // Sementara tidak digunakan
}

// =============================================================================
// Document System — Snapshot-on-Event PDF Foundation
// =============================================================================

enum DocType {
  PO
  PR
  GRN
  VENDOR_PROFILE
  INVOICE_AR
  INVOICE_AP
  FAKTUR_PAJAK
  PAYSLIP
  BOM
  SPK
}

model DocumentSnapshot {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  type          DocType
  entityId      String   @db.Uuid
  version       Int
  storageKey    String   // path inside "documents" bucket
  generatedAt   DateTime @default(now())
  generatedBy   String?  @db.Uuid
  triggerEvent  String   // e.g. "AUTO_PO_APPROVED" | "MANUAL_REGENERATE" | "BACKFILL"
  label         String?
  tags          String[]
  archivedAt    DateTime?
  metadata      Json?
  distributions DocumentDistribution[]

  @@unique([type, entityId, version])
  @@index([type, entityId])
  @@index([generatedAt])
  @@map("document_snapshots")
}

model DocumentDistribution {
  id              String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  snapshotId      String           @db.Uuid
  snapshot        DocumentSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Restrict)
  action          String           // "PRINT" | "DOWNLOAD" | "EMAIL"
  actorId         String           @db.Uuid
  recipientEmail  String?
  timestamp       DateTime         @default(now())
  notes           String?

  @@index([snapshotId])
  @@index([timestamp])
  @@map("document_distributions")
}
