  RET_EXPIRED      // Barang kadaluarsa
  ADJ_OVERCHARGE   // Kelebihan tagih
  ADJ_DISCOUNT     // Diskon belum dipotong
  ADJ_UNDERCHARGE  // Kekurangan tagih
  ADJ_ADDCHARGE    // Biaya tambahan
  SVC_CANCEL       // Pembatalan jasa
