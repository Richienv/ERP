  remainingQty  Decimal    @db.Decimal(15, 4)
  referenceType String?
  referenceId   String?
  createdAt     DateTime   @default(now())

  @@index([productId])
  @@index([productId, warehouseId])
  @@index([createdAt])
  @@map("cost_layers")
}

